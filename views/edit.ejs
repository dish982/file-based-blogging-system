<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= post.title %></title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=1">
    
    <link rel="stylesheet" href="/css/style.css">
    

</head>
<body class="bg-[#fffdfa] min-h-screen font-sans text-gray-800 antialiased flex items-center justify-center p-4">

    <div class="w-full max-w-2xl bg-white p-8 rounded-2xl shadow-md border border-gray-100">
        <div class="mb-6">
            <h1 class="text-2xl font-extrabold text-maroon">Edit Post: <%= post.title %></h1>
            <p class="text-xs text-gray-500 font-medium mt-1">Update your story logs or modify content parameters safely.</p>
        </div>
        <form action="/update/<%= post.title %>" method="POST" class="space-y-5">

            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold uppercase tracking-wider text-gray-500">Story Content</label>
                <textarea name="content" rows=8 class="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl text-sm font-medium focus:outline-none focus:ring-2 focus:ring-maroon/20 focus:border-maroon focus:bg-white transition-all duration-200" required>
                    <%- post.content %></textarea>
            </div>

            <!-- Toggle -->
            <div class="inline-flex items-center gap-2 py-1 mb-4">
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Private</span>
                
                <div class="relative inline-block w-11 h-5">
                    <input id="switch-component-on" name="isPublic" value="true" type="checkbox" <%= post.isPublic ? 'checked' : '' %>
                        class="peer appearance-none w-11 h-5 bg-slate-200 checked:bg-maroon rounded-full cursor-pointer transition-colors duration-300" />
                    
                    <label for="switch-component-on" 
                        class="absolute top-0 left-0 w-5 h-5 bg-white rounded-full border border-slate-300 shadow-sm transition-transform duration-300 peer-checked:translate-x-6 peer-checked:border-maroon cursor-pointer">
                    </label>
                </div>
                
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Public</span>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="py-3 px-6 bg-maroon text-white font-bold rounded-xl hover:bg-maroon-hover active:scale-[0.99] transition-all duration-200 text-sm shadow-md shadow-maroon/10">
                    Update</button>
                <a href="/" class="py-3 px-6 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl text-center transition-all duration-200 text-sm border border-gray-200">
                    Cancel & Go Back
                </a>
            </div>
            
            
        </form>

    </div>

    

</body>
</html>
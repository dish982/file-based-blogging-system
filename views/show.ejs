<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {extend: {colors: {maroon: {
                            DEFAULT: '#722f37',
                            hover: '#5c242a',
                            light: '#fdfafb'
                        }}}}}
    </script>
</head>
<body class="bg-[#fffdfa] min-h-screen font-sans text-gray-800 antialiased">
    
    <nav class="bg-white border-b border-gray-100 shadow-sm py-4">
        <div class="max-w-4xl mx-auto px-4 flex items-center justify-between">
            <span class="text-xl font-extrabold text-maroon tracking-tight">WordWeave Single Log</span>
            <a href="/" class="text-sm font-bold text-gray-500 hover:text-maroon transition-colors">← Dashboard</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-12">
        <article class="bg-white p-8 sm:p-12 rounded-2xl shadow-sm border border-gray-100 space-y-6">
            <header class="border-b border-gray-100 pb-6">
                <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight leading-tight mb-3">
                    <%= post.title %></h1>
            </header>

            <section class="text-base sm:text-lg text-gray-700 font-medium">
                <%- post.content %>
            </section>

            <footer class="border-t border-gray-100 pt-8 flex items-center gap-3">
                <% 
                const loggedInId = (locals.user && (user._id || user.id)) ? (user._id || user.id).toString() : null;
                const postAuthorId = post.userId && post.userId._id ? post.userId._id.toString() : (post.userId ? post.userId.toString() : '');
                %>
                <% if (loggedInId && loggedInId === postAuthorId) { %>
                
                <a href="/edit/<%= encodeURIComponent(post.title) %>" class="px-4 py-2 border border-maroon/20 hover:border-maroon/40 text-maroon text-xs font-bold rounded-xl transition-colors bg-maroon/5">
                    Edit Document
                </a>
                <% } %>
                <a href="/" class="px-4 py-2 border border-gray-200 hover:border-gray-300 text-gray-500 text-xs font-bold rounded-xl transition-colors bg-gray-50">
                    Back to Feed
                </a>
            </footer>

            
        </article>
    </main>



    
    
    
</body>
</html>